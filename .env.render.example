# Render Environment Variables Template
# Paste these as environment variables in Render dashboard.

FLASK_ENV=production
SECRET_KEY=replace-with-random-secret

# Supabase shared/session pooler URL
DATABASE_URL=postgresql://postgres.ofmbwelgabhpfbvhbgix:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
MASTER_DATABASE_URL=postgresql://postgres.ofmbwelgabhpfbvhbgix:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

AUTO_CREATE_TABLES=false
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=180
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Admin Authentication (JWT)
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=replace-with-random-jwt-secret
ADMIN_USERNAME=gramscs
# Generate hash: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('YOUR_PASSWORD', method='pbkdf2:sha256'))"
ADMIN_PASSWORD_HASH=replace-with-hashed-password
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7
