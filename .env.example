# Environment Configuration Template
# Copy this to .env and fill in with your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (required)
# PostgreSQL connection string.
# Supabase (shared/session pooler) example:
# postgresql://postgres.ofmbwelgabhpfbvhbgix:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Optional separate PostgreSQL connection string for ETA master data.
# If omitted, the app falls back to DATABASE_URL for local development.
# For now you can use the same Supabase URL as DATABASE_URL.
MASTER_DATABASE_URL=

# Do not auto-create tables in production. Use migrations/manual SQL instead.
AUTO_CREATE_TABLES=false

# Optional database pool tuning (recommended for Supabase pooler + Render).
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=180
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# Optional: Logging
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Admin Authentication (JWT)
# ---------------------------------------------------------------------------
# A strong random secret used to sign JWT tokens.  Must be changed in production.
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Admin login username.
ADMIN_USERNAME=gramscs

# Werkzeug-hashed password for the admin user.
# Generate with: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('YOUR_PASSWORD', method='pbkdf2:sha256'))"
# Default hash below corresponds to the password: frm@2019
ADMIN_PASSWORD_HASH=pbkdf2:sha256:1000000$9BN8ajs5UISV3KCL$0c416d88210d30bbe434971f8052a8ba8b0c8af8eab8fef0ebe7d1376c2ccaec

# Access token lifetime in minutes (default: 15).
ACCESS_TOKEN_EXPIRES_MINUTES=15

# Refresh token lifetime in days (default: 7).
REFRESH_TOKEN_EXPIRES_DAYS=7