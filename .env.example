# Environment Configuration Template
# Copy this to .env and fill in with your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (required)
# PostgreSQL connection string, e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Optional separate PostgreSQL connection string for ETA master data.
# If omitted, the app falls back to DATABASE_URL for local development.
MASTER_DATABASE_URL=

# Email Configuration (for contact form)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Contact Form Recipient
CONTACT_EMAIL_RECIPIENT=your-email@gmail.com

# Optional: Logging
LOG_LEVEL=INFO