# Environment Configuration Template
# Copy this to .env and fill in with your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (required)
# PostgreSQL connection string.
# Supabase (shared/session pooler) example:
# postgresql://postgres.ofmbwelgabhpfbvhbgix:<DB_PASSWORD>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Optional separate PostgreSQL connection string for ETA master data.
# If omitted, the app falls back to DATABASE_URL for local development.
# For now you can use the same Supabase URL as DATABASE_URL.
MASTER_DATABASE_URL=

# Do not auto-create tables in production. Use migrations/manual SQL instead.
AUTO_CREATE_TABLES=false

# Optional database pool tuning (recommended for Supabase pooler + Render).
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=180
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# Optional: Logging
LOG_LEVEL=INFO